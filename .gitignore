# Build artifacts
*.o
*.exe
*.dll
*.a

# Windows NUL device artifact (created when Makefile runs under bash)
NUL

# Debug / log output
*.log

# Claude project memory (local only)
.claude/

# AI sidecar binaries and model (created by setup.bat)
ai/

# Session logs (generated at runtime)
logs/

# Local temp directory (used by setup instead of %TEMP%/AppData)
tmp/

# LLM model files (large binaries)
*.gguf
*.bin
*.ggml
models/
